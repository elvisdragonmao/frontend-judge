    "templates": {
      "html-required-elements": {
        "name": "必要 HTML 元素检查",
        "description": "检查页面是否包含指定的 HTML 元素，例如 nav、header、footer、main、h1。",
        "params": {
          "selectors": {
            "label": "要检查的 CSS selectors（每行一个）",
            "placeholder": "nav\nheader\nfooter\nmain\nh1"
          }
        }
      },
      "html-element-count": {
        "name": "HTML 元素数量检查",
        "description": "检查特定元素数量是否符合预期，例如 li、img、a。",
        "params": {
          "rules": {
            "label": "规则（每行一条：selector,最少数量）",
            "placeholder": "li,3\nimg,2\na,5"
          }
        }
      },
      "html-form-elements": {
        "name": "表单元素检查",
        "description": "检查页面是否具有完整的表单结构。",
        "params": {
          "formSelector": {
            "label": "表单 selector",
            "placeholder": "form"
          },
          "inputNames": {
            "label": "必要 input name 属性（每行一个）",
            "placeholder": "name\nemail\npassword"
          },
          "requireSubmitButton": {
            "label": "需要 submit 按钮 (1=是, 0=否)",
            "placeholder": "1"
          }
        }
      },
      "styling-property-check": {
        "name": "CSS 样式属性检查",
        "description": "检查元素是否具有指定的 CSS 属性值。",
        "params": {
          "rules": {
            "label": "规则（每行一条：selector | 属性 | 预期值）",
            "placeholder": "nav | display | flex\nh1 | font-size | 24px\nbody | margin | 0px"
          }
        }
      },
      "styling-responsive": {
        "name": "RWD 响应式检查",
        "description": "在不同窗口宽度下检查元素可见性或样式。",
        "params": {
          "rules": {
            "label": "规则（每行一条：宽度 | selector | visible/hidden）",
            "placeholder": "375 | .desktop-nav | hidden\n375 | .mobile-menu | visible\n1024 | .desktop-nav | visible"
          }
        }
      },
      "styling-no-default": {
        "name": "禁止浏览器默认样式",
        "description": "检查页面是否移除默认样式并套用自定义字体或背景。",
        "params": {
          "bodyNoMargin": {
            "label": "检查 body 无默认 margin (1=是)",
            "placeholder": "1"
          },
          "customFont": {
            "label": "检查是否使用自定义字体 (1=是)",
            "placeholder": "1"
          },
          "hasBackground": {
            "label": "检查 body 有自定义背景色 (1=是)",
            "placeholder": "0"
          }
        }
      },
      "func-click-event": {
        "name": "按钮点击事件",
        "description": "点击按钮后检查页面是否出现预期变化。",
        "params": {
          "buttonSelector": {
            "label": "按钮 selector",
            "placeholder": "#myButton"
          },
          "resultSelector": {
            "label": "结果显示的 selector",
            "placeholder": "#result"
          },
          "expectedText": {
            "label": "预期出现的文字",
            "placeholder": "Hello!"
          }
        }
      },
      "func-form-submit": {
        "name": "表单提交验证",
        "description": "填写表单字段并提交，检查提交后的结果或验证信息。",
        "params": {
          "fields": {
            "label": "字段填写（每行：selector | 值）",
            "placeholder": "#name | 小明\n#email | test@example.com"
          },
          "submitSelector": {
            "label": "提交按钮 selector",
            "placeholder": "button[type=\"submit\"]"
          },
          "successSelector": {
            "label": "成功消息 selector",
            "placeholder": ".success-message"
          },
          "successText": {
            "label": "成功消息文字（留空表示只检查可见性）",
            "placeholder": "提交成功"
          }
        }
      },
      "func-localstorage": {
        "name": "LocalStorage 数据保存",
        "description": "检查交互后是否正确使用 localStorage 保存数据。",
        "params": {
          "action": {
            "label": "触发动作（click selector）",
            "placeholder": "#saveBtn"
          },
          "storageKey": {
            "label": "localStorage key",
            "placeholder": "userData"
          }
        }
      },
      "page-title": {
        "name": "页面标题检查",
        "description": "检查 <title> 是否包含指定文字。",
        "params": {
          "title": {
            "label": "预期标题（支持正则）",
            "placeholder": "My Website"
          }
        }
      },
      "page-meta": {
        "name": "页面 meta 标签检查",
        "description": "检查 meta viewport、charset、description 是否正确设置。",
        "params": {
          "requireViewport": {
            "label": "需要 viewport meta (1=是)",
            "placeholder": "1"
          },
          "requireCharset": {
            "label": "需要 charset meta (1=是)",
            "placeholder": "1"
          },
          "requireDescription": {
            "label": "需要 description meta (1=是)",
            "placeholder": "1"
          }
        }
      },
      "page-multi-page": {
        "name": "多页面导航检查",
        "description": "检查网站是否有多个页面，链接是否能正常导航。",
        "params": {
          "links": {
            "label": "要检查的页面路径（每行一条：路径 | 预期标题或元素 selector）",
            "placeholder": "/ | h1\n/about | h1\n/contact | form"
          }
        }
      },
      "page-no-console-errors": {
        "name": "无 Console 错误",
        "description": "确认页面加载后没有 JavaScript console error。"
      },
      "page-accessibility": {
        "name": "基础无障碍检查",
        "description": "检查图片 alt、语义化标签与 heading 顺序等基础无障碍项目。"
      },
      "screenshot-capture": {
        "name": "截图抓取",
        "description": "加载页面后抓取整页截图。",
        "params": {
          "pages": {
            "label": "要截图的路径（每行一条）",
            "placeholder": "/\n/about"
          }
        }
      },
      "react-component-render": {
        "name": "React 组件渲染检查",
        "description": "检查 React 组件是否正确渲染，props 数据是否显示。",
        "params": {
          "selectors": {
            "label": "要检查的元素 selector（每行一个：selector | 预期文字）",
            "placeholder": "[data-testid=\"app-title\"] | My App\n[data-testid=\"user-list\"] |"
          }
        }
      },
      "react-state-interaction": {
        "name": "React 状态交互检查",
        "description": "检查 React 组件状态管理，例如 counter、toggle、list。",
        "params": {
          "scenario": {
            "label": "情境 (counter / toggle / list)",
            "placeholder": "counter"
          }
        }
      }
    }
  },
