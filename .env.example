# API
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/judge
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
DEFAULT_ADMIN_PASSWORD=admin123

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_PUBLIC_BASE_URL=/img

# Worker
WORKER_ID=worker-1
POLL_INTERVAL_MS=3000
WORK_DIR=/tmp/judge-work
JUDGE_PNPM_STORE_DIR=.cache/judge-pnpm-store
JUDGE_PNPM_STORE_MOUNT_PATH=/pnpm/store
JUDGE_PNPM_STORE_CLEANUP_HOUR_TW=5
DOCKER_BIN=docker
JUDGE_IMAGE=judge-runner:latest
